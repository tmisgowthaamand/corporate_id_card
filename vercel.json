{
  "version": 2,
  "builds": [
    {
      "src": "id-card-generator/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "id-card-generator/frontend/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/id-card-generator/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/id-card-generator/backend/app.py"
    }
  ]
}
